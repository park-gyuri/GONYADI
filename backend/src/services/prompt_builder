# ── 내부용 함수 ────────────────────────────────────────────────────

def _budget_label(budget: int) -> str:
    # _ 접두사 → 이 파일 안에서만 쓰는 함수
    # 숫자 예산을 AI가 이해하기 쉬운 문장으로 변환
    if budget == 0:        return "예산 무관"
    elif budget < 50_000:  return f"1인 {budget // 10_000}만원 이하 (저예산)"
    # 50_000 → 50000과 같음, 가독성을 위한 구분자
    # // → 정수 나눗셈 (소수점 버림)
    elif budget < 150_000: return f"1인 {budget // 10_000}만원 (중간)"
    else:                  return f"1인 {budget // 10_000}만원 이상 (여유있게)"


# ── 메인 함수 ──────────────────────────────────────────────────────

def build_hybrid_prompt(req: RecommendRequest) -> str:
    # RecommendRequest 객체를 받아서 AI용 프롬프트 문자열을 반환

    # 날짜 있으면 날짜 포함, 없으면 기간만
    if req.start_date and req.end_date:
        schedule_str = f"{req.start_date} ~ {req.end_date} ({req.nights}박 {req.days}일)"
    else:
        schedule_str = f"{req.nights}박 {req.days}일 (날짜 미정)"

    # 사용자가 선택한 테마들을 꺼내서 배경 설명 붙여 여러 줄 문자열로 만들기
    # for t in req.themes        → 선택한 테마를 하나씩 꺼냄
    # t.value                    → Enum의 한글 값 (예: "힐링")
    # THEME_EXPLANATION[t]       → 해당 테마의 배경 설명
    # "\n".join()                → 각 줄을 줄바꿈으로 이어붙임
    theme_details = "\n".join(
        f"  - {t.value}: {THEME_EXPLANATION[t]}"
        for t in req.themes
    )
    # 결과 예시:
    # "  - 힐링: 스파, 온천...
    #    - 맛집: 현지인 맛집..."

    # 여행 조건이 있을 때만 섹션 생성
    condition_notes = "\n".join(
        f"  - {c.value}: {CONDITION_EXPLANATION[c]}"
        for c in req.conditions
        # conditions가 [] 이면 for문이 실행 안 됨 → condition_notes = ""
    )
    condition_section = f"\n[필수 조건]\n{condition_notes}" if condition_notes else ""
    # condition_notes가 "" 이면 condition_section도 "" → 프롬프트에서 통째로 사라짐

    # 상세 요청이 있을 때만 섹션 생성
    user_request_section = (
        f'\n[상세 요청]\n"{req.user_message}"'
        if req.user_message.strip() else ""
        # .strip() → 앞뒤 공백 제거 후 빈 문자열이면 False
    )

    # 위에서 만든 변수들을 템플릿에 끼워넣어 최종 프롬프트 완성
    return f"""
당신은 한국 여행 일정 전문 큐레이터입니다.

[여행 기본 정보]
- 지역: {req.region}
- 일정: {schedule_str}
- 인원: {req.number_of_people}명
- 1인 예산: {_budget_label(req.budget_per_person)}
- 이동 수단: {req.transport.value} ({TRANSPORT_EXPLANATION[req.transport]})

[여행 테마]
{theme_details}
{condition_section}
{user_request_section}

위 조건을 모두 반영하여 {req.days}일 일정에 맞는 장소를 추천해 주세요.
필수 조건이 있다면 반드시 지키고, 상세 요청을 최우선으로 반영해 주세요.
""".strip()
# .strip() → f""" 시작할 때 생기는 앞뒤 줄바꿈 제거


def get_loading_message(req: RecommendRequest) -> str:
    # 프론트 로딩 화면(화면 B)에 보여줄 문구 생성

    # 선택한 테마 이름들을 ", "로 이어붙임
    theme_names = ", ".join(t.value for t in req.themes)
    # 예: "힐링, 맛집, 카페"

    return (
        f"{req.region} {req.nights}박 {req.days}일, "
        f"{req.number_of_people}명 {_budget_label(req.budget_per_person)} "
        f"코스를 분석 중입니다..."
    )
    # 괄호 안에서 f-string을 여러 줄로 나눈 것
    # 실제 출력은 한 줄로 이어짐
    # 예: "서울 2박 3일, 2명 1인 8만원 (중간) 코스를 분석 중입니다..."